# Syncore REST API (for job lookup)
SYNCORE_API_KEY=

# Syncore web login (for writing Job Tracker entries — no REST API exposed for that)
# Same credentials used by UPS-Shipping-Import
SYNCORE_USERNAME=
SYNCORE_PASSWORD=

# HMAC secret for signing scan tokens (generate: openssl rand -base64 32)
PICKUP_HMAC_SECRET=

# Gmail SMTP (reuse app password from UPS-Shipping-Import, or generate new at myaccount.google.com → Security → App passwords)
GMAIL_USER=kiley@colorgraphicswa.com
GMAIL_APP_PASSWORD=

# Public URL of this app (used in the QR payload)
PUBLIC_BASE_URL=http://localhost:3000

# Simple shared-secret gate for admin pages (/, /sticker/*)
ADMIN_PASSWORD=

# Where pickup-confirmation emails are sent (single address or comma-separated list)
PICKUP_EMAIL_TO=csr@colorgraphicswa.com

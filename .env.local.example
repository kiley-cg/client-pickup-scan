# Syncore REST API (read-only — used for job lookup)
SYNCORE_API_KEY=

# Syncore web login (writes to the Job Tracker — no REST endpoint exposed)
# Account must NOT have MFA enabled or the scraper will fail.
SYNCORE_USERNAME=
SYNCORE_PASSWORD=

# HMAC secret for signing scan tokens (generate: openssl rand -base64 32)
PICKUP_HMAC_SECRET=

# Public URL of this app (used in the QR payload + email links)
PUBLIC_BASE_URL=http://localhost:3000

# Shared-secret gate for /, /sticker/*, /admin/*
ADMIN_PASSWORD=

# Resend.com (https://resend.com/api-keys)
# EMAIL_FROM must be on a domain verified in Resend.
RESEND_API_KEY=
EMAIL_FROM=Color Graphics <alerts@updates.colorgraphicswa.com>
EMAIL_REPLY_TO=alerts@colorgraphicswa.com

# Where pickup-confirmation emails are sent (single address or comma-separated)
PICKUP_EMAIL_TO=csr@colorgraphicswa.com

# Name → email map for routing the staff "Ready for pickup" email.
# Format: comma-separated "Full Name=email" pairs (case-insensitive on the name).
# Names must match what Syncore returns on primary_rep.name and customer_service_rep_name.
REP_EMAIL_MAP=

# Shared secret between the Netlify scheduled function and /api/cron/send-reminders
# (generate: openssl rand -base64 32)
CRON_SECRET=

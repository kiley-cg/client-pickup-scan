# Syncore
SYNCORE_API_KEY=

# HMAC secret for signing scan tokens (generate: openssl rand -base64 32)
PICKUP_HMAC_SECRET=

# Gmail SMTP (reuse app password from UPS-Shipping-Import, or generate new at myaccount.google.com → Security → App passwords)
GMAIL_USER=kiley@colorgraphicswa.com
GMAIL_APP_PASSWORD=

# Public URL of this app (used in the QR payload)
PUBLIC_BASE_URL=http://localhost:3000

# Simple shared-secret gate for admin pages (/, /sticker/*)
ADMIN_PASSWORD=

# Optional: rep-email fallback. Comma-separated name=email pairs, e.g.
#   "John Smith=john@colorgraphicswa.com,Jane Doe=jane@colorgraphicswa.com"
# Only used when Syncore doesn't return a rep email on the job.
REP_EMAIL_MAP=

# Optional: override the CSR fallback recipient if no rep email is available
CSR_FALLBACK_EMAIL=
